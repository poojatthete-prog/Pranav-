rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net (default-deny catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Entity validation
    function isValidTask(data) {
      return data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.completed is bool
        && data.category is string && data.category.size() <= 50;
    }

    function isValidEvent(data) {
      return data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.time is string && data.time.size() <= 50
        && data.date is string && data.date.size() <= 50
        && data.category is string && data.category.size() <= 50;
    }

    // Collection paths
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /tasks/{taskId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(taskId) && isValidTask(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /events/{eventId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(eventId) && isValidEvent(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
